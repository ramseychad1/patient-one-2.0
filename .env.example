# Pooler — HikariCP runtime queries
SPRING_DATASOURCE_URL=jdbc:postgresql://your-pooler-host:5432/postgres
SPRING_DATASOURCE_USERNAME=your-pooler-username
SPRING_DATASOURCE_PASSWORD=your-password

# Direct — Flyway migrations only (PgBouncer breaks advisory locks)
FLYWAY_DATASOURCE_URL=jdbc:postgresql://your-direct-db-host:5432/postgres
FLYWAY_DATASOURCE_USERNAME=postgres

# JWT — generate with: openssl rand -base64 64
JWT_SECRET=your-jwt-secret-min-256-bits

# Demo
DEMO_SCENARIO=DEFAULT
SPRING_PROFILES_ACTIVE=dev
